{
  "name": "receptify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "start": "next dev -p 3000 -H 0.0.0.0",
    "build": "next build",
    "serve": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "typeorm": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/lib/db/data-source.ts",
    "db:migrate": "yarn typeorm migration:run",
    "db:generate": "yarn typeorm migration:generate src/lib/db/migrations/Auto",
    "db:revert": "yarn typeorm migration:revert",
    "db:show": "yarn typeorm migration:show",
    "db:seed": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register src/lib/db/seed.ts"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "19.0.0-rc-69d4b800-20241021",
    "react-dom": "19.0.0-rc-69d4b800-20241021",
    "typescript": "5.6.3",
    "@types/node": "22.9.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "tailwindcss": "3.4.14",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "typeorm": "0.3.20",
    "pg": "8.13.1",
    "@types/pg": "8.11.10",
    "reflect-metadata": "0.2.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "bcryptjs": "2.4.3",
    "@types/bcryptjs": "2.4.6",
    "jsonwebtoken": "9.0.2",
    "@types/jsonwebtoken": "9.0.7",
    "zod": "3.23.8",
    "lucide-react": "0.460.0",
    "recharts": "2.13.3",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.4",
    "papaparse": "5.4.1",
    "@types/papaparse": "5.3.15",
    "class-variance-authority": "0.7.0",
    "sonner": "1.7.0",
    "date-fns": "4.1.0"
  },
  "devDependencies": {
    "eslint": "8.57.1",
    "eslint-config-next": "15.0.3"
  }
}
